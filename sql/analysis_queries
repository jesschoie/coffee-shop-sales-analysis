-- Convert transaction_date and transaction_time to date and time format
SELECT transaction_date, 
	   STR_TO_DATE(transaction_date, '%e/%m/%Y'), 
       transaction_time, 
	   STR_TO_DATE(transaction_time, '%k:%i:%S')
FROM sales;

UPDATE sales
SET transaction_date = STR_TO_DATE(transaction_date, '%e/%m/%Y'),
	transaction_time = STR_TO_DATE(transaction_time, '%k:%i:%S');

ALTER TABLE sales
MODIFY COLUMN transaction_date DATE,
MODIFY COLUMN transaction_time TIME;

-- Add a Revenue column
ALTER TABLE sales
ADD revenue DOUBLE;

UPDATE sales
SET revenue = ROUND(transaction_qty*unit_price,2);

-- Determine the Date Range of the data
SELECT MIN(transaction_date) AS min_date, 
	   MAX(transaction_date) AS max_date
FROM sales;

-- Total Number of Products
SELECT COUNT(DISTINCT product_detail) AS total_product_detail, 
	   COUNT(DISTINCT product_type) AS total_product_types, 
       COUNT(DISTINCT product_category) AS total_product_categories
FROM sales;

-- Total Revenue and Quantity Sold per Product Category
SELECT product_category, 
	   ROUND(SUM(revenue),2) AS revenue,
       SUM(transaction_qty) AS quantity_sold
FROM sales
GROUP BY product_category
ORDER BY revenue DESC;

-- Top 10 Product Types by Revenue
SELECT product_type, 
	   ROUND(SUM(revenue),2) AS revenue
FROM sales
GROUP BY product_type
ORDER BY revenue DESC
LIMIT 10;

-- Top 10 Products by Revenue
SELECT product_detail, 
	   ROUND(SUM(revenue),2) AS revenue
FROM sales
GROUP BY product_detail
ORDER BY revenue DESC
LIMIT 10;

-- Top 10 Product Types by Quantity Sold
SELECT product_type, 
	   SUM(transaction_qty) AS quantity_sold
FROM sales
GROUP BY product_type
ORDER BY quantity_sold DESC
LIMIT 10;

-- Top 10 Products by Quantity Sold
SELECT product_detail, 
	   SUM(transaction_qty) AS quantity_sold
FROM sales
GROUP BY product_detail
ORDER BY quantity_sold DESC
LIMIT 10;

-- Revenue/Transactions per Month
SELECT MONTH(transaction_date) AS month, 
	   ROUND(SUM(revenue),2) AS revenue, 
       COUNT(transaction_qty) AS transactions
FROM sales
GROUP BY month
ORDER BY month;

-- Revenue per Hour
SELECT HOUR(transaction_time) AS hour, 
	   ROUND(SUM(revenue),2) AS revenue
FROM sales
GROUP BY hour
ORDER BY hour;

-- Revenue by Store
SELECT store_location, 
	   ROUND(SUM(revenue),2) AS revenue
FROM sales
GROUP BY store_location
ORDER BY revenue DESC;

-- Revenue by Day of Week
SELECT DAYNAME(transaction_date) AS weekday, 
	   ROUND(SUM(revenue),2) AS revenue
FROM sales
GROUP BY weekday;

-- Number of Transactions by Day of Week
SELECT DAYNAME(transaction_date) AS weekday, 
	   COUNT(transaction_qty) AS transactions
FROM sales
GROUP BY weekday;

-- Number of Transactions by Hour of Day
SELECT HOUR(transaction_time) AS hour, 
	   COUNT(transaction_qty) AS transactions
FROM sales
GROUP BY hour
ORDER BY hour;

-- Average Number of Transactions by Hour of Day per Store
SELECT store_location, 
	   HOUR(transaction_time) AS hour, 
       COUNT(transaction_qty)/COUNT(DISTINCT transaction_date) AS avg_transactions
FROM sales
GROUP BY hour, 
		 store_location
ORDER BY hour;

-- Average Number of Transactions/Revenue/Quantity per Day per Store
SELECT store_location, 
	   ROUND(COUNT(transaction_qty)/COUNT(DISTINCT transaction_date),0) AS avg_transactions_per_day, 
       ROUND(SUM(revenue)/COUNT(DISTINCT transaction_date),2) AS avg_revenue_per_day,
       ROUND(SUM(transaction_qty)/COUNT(DISTINCT transaction_date),0) AS avg_quantity_sold_per_day
FROM sales
GROUP BY store_location;

-- Percentage Change in Revenue per Month
WITH monthly_revenue AS (
	SELECT MONTH(transaction_date) AS month, 
		   ROUND(SUM(revenue),2) AS monthly_revenue
	FROM sales
	GROUP BY month
),

previous_revenue AS (
	SELECT month, 
		   monthly_revenue, 
		   LAG(monthly_revenue) OVER (ORDER BY month) AS previous_revenue
	FROM monthly_revenue
)

SELECT month, 
	   monthly_revenue, 
       COALESCE(ROUND((monthly_revenue-previous_revenue)*100/previous_revenue,2),'N/A') AS percentage_change
FROM previous_revenue
